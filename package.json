{
  "name": "safedrop-cli",
  "version": "1.0.1",
  "description": "Zero-knowledge, end-to-end encrypted file transfer from your terminal. Fully compatible with the SafeDrop web app.",
  "type": "module",
  "bin": {
    "safedrop": "src/cli.js"
  },
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./crypto": "./src/crypto.js",
    "./code": "./src/code.js"
  },
  "files": [
    "src",
    "README.md",
    "API.md",
    "SECURITY.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test test/",
    "start": "node src/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "safedrop",
    "encryption",
    "aes-256-gcm",
    "zero-knowledge",
    "file-transfer",
    "e2ee",
    "cli",
    "secure"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/taha-labrahimi/safedrop_cli.git"
  },
  "homepage": "https://safedrop.ma",
  "bugs": {
    "url": "https://github.com/taha-labrahimi/safedrop_cli/issues"
  },
  "dependencies": {}
}
